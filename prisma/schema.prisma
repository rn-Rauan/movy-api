// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RoleName {
  ADMIN
  DRIVER
  PASSENGER
}

enum RouteType {
  ONE_WAY
  RETURN
  ROUND_TRIP
}

enum TripStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MethodPayment {
  MONEY
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
}

enum PlanName {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            PlanName       @default(FREE)
  price           Decimal        @db.Decimal(10, 2)
  maxVehicles     Int
  maxDrivers      Int
  maxMonthlyTrips Int
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  subscriptions  Subscription[] @relation("PlanSubscriptions")

  @@map("plan")
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  cnpj          String   @unique
  email         String   @unique
  telephone     String
  slug          String   @unique
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users         User[]           @relation("UserOrganization")
  vehicles      Vehicle[]        @relation("VehicleOrganization")
  tripTemplates TripTemplate[]   @relation("TripTemplateOrganization")
  payments      Payment[]        @relation("PaymentOrganization")
  enrollments   Enrollment[]     @relation("EnrollmentOrganization")
  auditLogs     AuditLog[]       @relation("AuditLogOrganization")
  subscriptions Subscription[]   @relation("OrganizationSubscription")

  @@map("organization")
}

model Subscription {
  id               String             @id @default(uuid())
  organizationId   String
  planId           Int
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime
  expiresAt        DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  organization     Organization       @relation("OrganizationSubscription", fields: [organizationId], references: [id])
  plan             Plan               @relation("PlanSubscriptions", fields: [planId], references: [id])

  @@map("subscriptions")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users User[] @relation("UserRoles")

  @@map("role")
}

model User {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  passwordHash   String
  telephone      String
  organizationId String? //Null for basic users, required for organization members
  status         Status       @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  roles        Role[]         @relation("UserRoles")
  organization Organization?  @relation("UserOrganization", fields: [organizationId], references: [id])
  driver       Driver?        @relation("DriverUser")
  enrollments  Enrollment[]   @relation("EnrollmentUser")
  auditLogs    AuditLog[]     @relation("AuditLogUser")

  @@map("user")
}

model Driver {
  userId        String         @id
  cnh           String
  cnhCategory   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  user          User           @relation("DriverUser", fields: [userId], references: [id])
  tripInstances TripInstance[] @relation("TripDriver")

  @@map("driver")
}

model Vehicle {
  id             String         @id @default(uuid())
  plate          String         @unique
  model          String
  type           String
  maxCapacity    Int
  status         Status         @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization  Organization   @relation("VehicleOrganization", fields: [organizationId], references: [id])
  tripInstances TripInstance[] @relation("TripVehicle")

  @@map("vehicle")
}

model TripTemplate {
  id             String      @id @default(uuid())
  departurePoint String
  destination    String
  routeType      RouteType
  priceOneWay    Decimal?    @db.Decimal(10, 2)
  priceReturn    Decimal?    @db.Decimal(10, 2)
  priceRoundTrip Decimal?    @db.Decimal(10, 2)
  isRecurring    Boolean
  frequency      DayOfWeek[]
  shift          Shift
  status         Status      @default(ACTIVE)
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  //Relations
  organization  Organization   @relation("TripTemplateOrganization", fields: [organizationId], references: [id])
  tripInstances TripInstance[] @relation("TripInstanceTemplate")

  @@map("trip_template")
}

model TripInstance {
  id                     String     @id @default(uuid())
  driverId               String
  vehicleId              String
  totalCapacity          Int
  tripStatus             TripStatus @default(SCHEDULED)
  tripTemplateId         String
  statusForRecurringTrip Status? // Only for recurring trips
  departureTime          DateTime
  arrivalEstimate        DateTime
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  driver       Driver       @relation("TripDriver", fields: [driverId], references: [userId])
  vehicle      Vehicle      @relation("TripVehicle", fields: [vehicleId], references: [id])
  tripTemplate TripTemplate @relation("TripInstanceTemplate", fields: [tripTemplateId], references: [id])
  enrollments  Enrollment[] @relation("EnrollmentTripInstance")

  @@map("trip_instance")
}

model Enrollment {
  id                String     @id @default(uuid())
  enrollmentDate    DateTime
  status            Status     @default(ACTIVE)
  presenceConfirmed Boolean    @default(false)
  routeType         RouteType
  recordedPrice     Decimal    @db.Decimal(10, 2)
  userId            String
  tripInstanceId    String
  boardingPoint     String
  organizationId    String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  user         User         @relation("EnrollmentUser", fields: [userId], references: [id])
  tripInstance TripInstance @relation("EnrollmentTripInstance", fields: [tripInstanceId], references: [id])
  payment      Payment?     @relation("PaymentEnrollment")
  organization Organization @relation("EnrollmentOrganization", fields: [organizationId], references: [id])

  @@map("enrollment")
}

model Payment {
  id             String        @id @default(uuid())
  organizationId String
  method         MethodPayment
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus
  enrollmentId   String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation("PaymentOrganization", fields: [organizationId], references: [id])
  enrollment   Enrollment   @relation("PaymentEnrollment", fields: [enrollmentId], references: [id])

  @@map("payment")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String
  timestamp      DateTime @default(now())

  // Relations
  organization Organization @relation("AuditLogOrganization", fields: [organizationId], references: [id])
  user         User         @relation("AuditLogUser", fields: [userId], references: [id])

  @@map("audit_log")
}