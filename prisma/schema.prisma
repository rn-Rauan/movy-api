// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RoleName {
  ADMIN
  DRIVER
  PASSENGER
}

enum RouteType {
  ONE_WAY
  RETURN
  ROUND_TRIP
}

enum TripStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MethodPayment {
  MONEY
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
}

enum PlanName {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            PlanName       @default(FREE) @unique
  price           Decimal        @db.Decimal(10, 2)
  maxVehicles     Int
  maxDrivers      Int
  maxMonthlyTrips Int
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  subscriptions  Subscription[] @relation("PlanSubscriptions")

  @@index([isActive])
  @@map("plan")
}

model Organization {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(255)
  cnpj          String   @unique
  email         String   @unique
  telephone     String   @db.VarChar(20)
  slug          String   @unique @db.VarChar(100)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users         User[]           @relation("UserOrganization")
  vehicles      Vehicle[]        @relation("VehicleOrganization")
  tripTemplates TripTemplate[]   @relation("TripTemplateOrganization")
  payments      Payment[]        @relation("PaymentOrganization")
  enrollments   Enrollment[]     @relation("EnrollmentOrganization")
  auditLogs     AuditLog[]       @relation("AuditLogOrganization")
  subscriptions Subscription[]   @relation("OrganizationSubscription")

  @@index([slug])
  @@index([status])
  @@map("organization")
}

model Subscription {
  id               String             @id @default(uuid())
  organizationId   String
  planId           Int
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime
  expiresAt        DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  organization     Organization       @relation("OrganizationSubscription", fields: [organizationId], references: [id], onDelete: Cascade)
  plan             Plan               @relation("PlanSubscriptions", fields: [planId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userRoles UserRole[] @relation("RoleToUserRole")

  @@map("role")
}

model User {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(255)
  email          String       @unique @db.VarChar(255)
  passwordHash   String
  telephone      String       @db.VarChar(20)
  organizationId String? //Null for basic users, required for organization members
  status         Status       @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  userRoles    UserRole[]     @relation("UserToUserRole")
  organization Organization?  @relation("UserOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  driver       Driver?        @relation("DriverUser")
  enrollments  Enrollment[]   @relation("EnrollmentUser")
  auditLogs    AuditLog[]     @relation("AuditLogUser")

  @@index([organizationId])
  @@index([status])
  @@map("user")
}

model UserRole {
  userId    String
  roleId    Int
  assignedAt DateTime @default(now())

  // Relations
  user User @relation("UserToUserRole", fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation("RoleToUserRole", fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

model Driver {
  userId        String         @id
  cnh           String         @unique @db.VarChar(20)
  cnhCategory   String         @db.VarChar(5)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  user          User           @relation("DriverUser", fields: [userId], references: [id], onDelete: Cascade)
  tripInstances TripInstance[] @relation("TripDriver")

  @@map("driver")
}

model Vehicle {
  id             String         @id @default(uuid())
  plate          String         @unique @db.VarChar(10)
  model          String         @db.VarChar(255)
  type           String         @db.VarChar(100)
  maxCapacity    Int
  status         Status         @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization   Organization   @relation("VehicleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  tripInstances  TripInstance[] @relation("TripVehicle")

  @@index([organizationId])
  @@index([status])
  @@map("vehicle")
}

model TripTemplate {
  id             String      @id @default(uuid())
  departurePoint String      @db.VarChar(255)
  destination    String      @db.VarChar(255)
  routeType      RouteType
  priceOneWay    Decimal?    @db.Decimal(10, 2)
  priceReturn    Decimal?    @db.Decimal(10, 2)
  priceRoundTrip Decimal?    @db.Decimal(10, 2)
  isRecurring    Boolean
  frequency      DayOfWeek[]
  shift          Shift
  status         Status      @default(ACTIVE)
  organizationId String
  isPublic       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  //Relations
  organization   Organization   @relation("TripTemplateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  tripInstances  TripInstance[] @relation("TripInstanceTemplate")

  @@index([organizationId])
  @@index([status])
  @@index([isPublic])
  @@map("trip_template")
}

model TripInstance {
  id                     String     @id @default(uuid())
  driverId               String
  vehicleId              String
  totalCapacity          Int
  tripStatus             TripStatus @default(SCHEDULED)
  tripTemplateId         String
  statusForRecurringTrip Status? // Only for recurring trips
  departureTime          DateTime
  arrivalEstimate        DateTime
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  driver       Driver               @relation("TripDriver", fields: [driverId], references: [userId], onDelete: Cascade)
  vehicle      Vehicle              @relation("TripVehicle", fields: [vehicleId], references: [id], onDelete: Cascade)
  tripTemplate TripTemplate         @relation("TripInstanceTemplate", fields: [tripTemplateId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]         @relation("EnrollmentTripInstance")

  @@index([driverId])
  @@index([vehicleId])
  @@index([tripTemplateId])
  @@index([tripStatus])
  @@index([departureTime])
  @@map("trip_instance")
}

model Enrollment {
  id                String     @id @default(uuid())
  enrollmentDate    DateTime   @default(now())
  status            Status     @default(ACTIVE)
  presenceConfirmed Boolean    @default(false)
  routeType         RouteType
  recordedPrice     Decimal    @db.Decimal(10, 2)
  userId            String
  tripInstanceId    String
  boardingPoint     String     @db.VarChar(255)
  organizationId    String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  user         User         @relation("EnrollmentUser", fields: [userId], references: [id], onDelete: Cascade)
  tripInstance TripInstance @relation("EnrollmentTripInstance", fields: [tripInstanceId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation("PaymentEnrollment")
  organization Organization @relation("EnrollmentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tripInstanceId])
  @@index([organizationId])
  @@index([status])
  @@map("enrollment")
}

model Payment {
  id             String        @id @default(uuid())
  organizationId String
  method         MethodPayment
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  enrollmentId   String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation("PaymentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation("PaymentEnrollment", fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("payment")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String   @db.VarChar(255)
  timestamp      DateTime @default(now())

  // Relations
  organization Organization @relation("AuditLogOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("AuditLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_log")
}