// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleName {
  ADMIN
  DRIVER
}

enum EnrollmentType {
  ONE_WAY
  RETURN
  ROUND_TRIP
}

enum TripStatus {
  DRAFT
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MethodPayment {
  MONEY
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
}

enum VehicleType {
  VAN
  BUS
  MINIBUS
  CAR
}

enum PlanName {
  FREE
  BASIC
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            PlanName       @default(FREE) @unique
  price           Decimal        @db.Decimal(10, 2)
  maxVehicles     Int
  maxDrivers      Int
  maxMonthlyTrips Int
  durationDays    Int            @default(30)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  subscriptions  Subscription[] @relation("PlanSubscriptions")

  @@index([isActive])
  @@map("plan")
}

model Organization {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(255)
  cnpj          String   @unique
  email         String   @unique
  telephone     String   @db.VarChar(20)
  address       String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(100)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  memberships   OrganizationMembership[]     @relation("UserMembershipOrganization")
  vehicles      Vehicle[]        @relation("VehicleOrganization")
  tripTemplates TripTemplate[]   @relation("TripTemplateOrganization")
  payments      Payment[]        @relation("PaymentOrganization")
  enrollments   Enrollment[]     @relation("EnrollmentOrganization")
  auditLogs     AuditLog[]       @relation("AuditLogOrganization")
  subscriptions Subscription[]   @relation("OrganizationSubscription")
  tripInstances  TripInstance[]    @relation("TripInstanceOrganization")
  schedulingConfig TripSchedulingConfig?      @relation("OrganizationSchedulingConfig")

  @@index([slug])
  @@index([status])
  @@map("organization")
}

model Subscription {
  id               String             @id @default(uuid())
  organizationId   String
  planId           Int
  status           SubscriptionStatus @default(ACTIVE)
  activeKey        String?            @unique
  startDate        DateTime
  expiresAt        DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  organization     Organization       @relation("OrganizationSubscription", fields: [organizationId], references: [id], onDelete: Cascade)
  plan             Plan               @relation("PlanSubscriptions", fields: [planId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userRoles OrganizationMembership[] @relation("RoleToMembership")

  @@map("role")
}

model User {
  id               String       @id @default(uuid())
  name             String       @db.VarChar(255)
  email            String       @unique @db.VarChar(255)
  passwordHash     String
  telephone        String       @db.VarChar(20)
  status           Status       @default(ACTIVE)
  emailVerifiedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  userRoles                OrganizationMembership[]   @relation("UserToMembership")
  driver                   Driver?                    @relation("DriverUser")
  enrollments              Enrollment[]               @relation("EnrollmentUser")
  auditLogs                AuditLog[]                 @relation("AuditLogUser")
  refreshTokens            RefreshToken[]             @relation("UserRefreshTokens")
  passwordResetTokens      PasswordResetToken[]       @relation("UserPasswordResetTokens")
  emailVerificationTokens  EmailVerificationToken[]   @relation("UserEmailVerificationTokens")

  @@index([status])
  @@map("user")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_token")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserEmailVerificationTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_token")
}

model RefreshToken {
  jti       String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OrganizationMembership {
  userId         String
  roleId         Int
  organizationId String
  assignedAt     DateTime @default(now())
  removedAt      DateTime?

  // Relations
  user User @relation("UserToMembership", fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation("RoleToMembership", fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization @relation("UserMembershipOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, organizationId])
  @@map("user_role")
}

model Driver {
  id             String         @id @default(uuid())
  userId         String         @unique
  cnh            String         @unique @db.VarChar(20)
  cnhCategory    String         @db.VarChar(5)
  cnhExpiresAt   DateTime
  driverStatus   DriverStatus   @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  user               User           @relation("DriverUser", fields: [userId], references: [id], onDelete: Cascade)
  tripInstances      TripInstance[] @relation("TripDriver")
  defaultInTemplates TripTemplate[] @relation("TripTemplateDefaultDriver")

  @@map("driver")
}

model Vehicle {
  id             String         @id @default(uuid())
  plate          String         @unique @db.VarChar(10)
  model          String         @db.VarChar(255)
  type           VehicleType
  maxCapacity    Int
  status         Status         @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization       Organization   @relation("VehicleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  tripInstances      TripInstance[] @relation("TripVehicle")
  defaultInTemplates TripTemplate[] @relation("TripTemplateDefaultVehicle")

  @@index([organizationId])
  @@index([status])
  @@map("vehicle")
}

model TripTemplate {
  id             String      @id @default(uuid())
  organizationId String

  departurePoint String      @db.VarChar(255)
  destination    String      @db.VarChar(255)
  frequency      DayOfWeek[]
  stops          String[]

  // Time-of-day in 'HH:mm' UTC — TripInstance.departureTime/arrivalEstimate are derived
  // by combining a YYYY-MM-DD date with these fields. Nullable at the schema level
  // for migration safety; entity enforces presence at create() time.
  departureTimeOfDay String?  @db.VarChar(5)
  arrivalTimeOfDay   String?  @db.VarChar(5)

  // Capacity snapshot copied into TripInstance.totalCapacity when the recurring
  // generation cron creates instances. Nullable at the schema level for migration
  // safety; entity enforces presence at create() time.
  defaultCapacity    Int?

  // Optional default driver/vehicle assigned to instances generated from this
  // template. When BOTH are set, the recurring generation promotes the new
  // instance from DRAFT to SCHEDULED automatically. onDelete: SetNull so that
  // removing a driver/vehicle never blocks deletion — the template simply
  // loses its default and future instances fall back to DRAFT.
  defaultDriverId    String?
  defaultVehicleId   String?

  priceOneWay    Decimal?    @db.Decimal(10, 2)
  priceReturn    Decimal?    @db.Decimal(10, 2)
  priceRoundTrip Decimal?    @db.Decimal(10, 2)

  isPublic           Boolean   @default(false)
  isRecurring        Boolean   @default(false)
  autoCancelEnabled  Boolean   @default(false)
  minRevenue         Decimal?  @db.Decimal(10, 2)
  autoCancelOffset   Int?      // Minutes before departureTime to evaluate auto-cancel
  
  status         Status      @default(ACTIVE)
  shift          Shift

  // Metadata
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  //Relations
  organization   Organization   @relation("TripTemplateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  tripInstances  TripInstance[] @relation("TripInstanceTemplate")
  defaultDriver  Driver?        @relation("TripTemplateDefaultDriver", fields: [defaultDriverId], references: [id], onDelete: SetNull)
  defaultVehicle Vehicle?       @relation("TripTemplateDefaultVehicle", fields: [defaultVehicleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([isPublic])
  @@index([defaultDriverId])
  @@index([defaultVehicleId])
  @@map("trip_template")
}

model TripInstance {
  id                     String     @id @default(uuid())
  driverId               String?
  vehicleId              String?
  tripTemplateId         String
  organizationId         String

  tripStatus             TripStatus @default(SCHEDULED)
  
  minRevenue             Decimal?   @db.Decimal(10, 2)  // Snapshot from template (null if autoCancelEnabled=false)
  autoCancelAt           DateTime?  // departureTime - autoCancelOffset (null if autoCancelEnabled=false)
  forceConfirm           Boolean    @default(false)

  totalCapacity          Int        // Snapshot of vehicle capacity at scheduling time
  isPublic               Boolean    @default(false)  // Snapshot of TripTemplate.isPublic at creation time
  departureTime          DateTime
  arrivalEstimate        DateTime

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  driver       Driver?               @relation("TripDriver", fields: [driverId], references: [id], onDelete: Restrict)
  vehicle      Vehicle?              @relation("TripVehicle", fields: [vehicleId], references: [id], onDelete: Restrict)
  tripTemplate TripTemplate         @relation("TripInstanceTemplate", fields: [tripTemplateId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]         @relation("EnrollmentTripInstance")
  organization Organization          @relation("TripInstanceOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  // Unique constraint that defends the recurring-generation cron against
  // duplicate inserts when multiple replicas race past the existsForTemplateOnDay
  // pre-check. The combination (template, exact departure time) is unique because
  // a template has one fixed time-of-day — re-running the cron for the same day
  // produces an identical departureTime, which the DB rejects with P2002.
  @@unique([tripTemplateId, departureTime])
  @@index([tripTemplateId, organizationId])
  @@index([driverId, organizationId])
  @@index([vehicleId, organizationId])
  @@index([tripStatus])
  @@index([isPublic])
  @@index([departureTime])
  @@index([autoCancelAt])
  @@index([organizationId])
  @@map("trip_instance")
}

model TripSchedulingConfig {
  id              String       @id @default(uuid())
  organizationId  String       @unique
  daysAhead       Int          @default(14)
  generationCron  String       @default("0 2 * * *")
  autoCancelCron  String       @default("*/15 * * * *")
  enabled         Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation("OrganizationSchedulingConfig", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("trip_scheduling_config")
}

model Enrollment {
  id                String     @id @default(uuid())
  enrollmentDate    DateTime   @default(now())
  status            Status     @default(ACTIVE)
  presenceConfirmed Boolean    @default(false)
  enrollmentType    EnrollmentType
  recordedPrice     Decimal    @db.Decimal(10, 2)
  activeKey         String?    @unique
  userId            String
  tripInstanceId    String
  boardingStop      String     @db.VarChar(255)   // Ex: "A2"
  alightingStop     String     @db.VarChar(255)   // Ex: "B2"
  organizationId    String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  user         User         @relation("EnrollmentUser", fields: [userId], references: [id], onDelete: Cascade)
  tripInstance TripInstance @relation("EnrollmentTripInstance", fields: [tripInstanceId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation("PaymentEnrollment")
  organization Organization @relation("EnrollmentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tripInstanceId])
  @@index([organizationId])
  @@index([status])
  @@index([userId, tripInstanceId, status])
  @@map("enrollment")
}

model Payment {
  id             String        @id @default(uuid())
  organizationId String
  method         MethodPayment
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  enrollmentId   String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation("PaymentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation("PaymentEnrollment", fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("payment")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String   @db.VarChar(255)
  details        Json?    // Context: entityType, entityId, changes, ipAddress, etc.
  timestamp      DateTime @default(now())

  // Relations
  organization Organization @relation("AuditLogOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("AuditLogUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_log")
}
