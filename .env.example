# ========================================
# DATABASE CONFIGURATION
# ========================================

# Database URL for application
DATABASE_URL="postgresql://docker:docker07@localhost:5705/movy?schema=public"

# Direct connection to the database (used for migrations)
# Note: use if you encounter migration issues
DIRECT_URL=""

# ========================================
# APPLICATION CONFIGURATION
# ========================================

# Server port
PORT=3001

# JWT secret key for signing tokens
JWT_SECRET=your_jwt_secret_key_here

# JWT expiration in seconds (1h = 3600, 7d = 604800)
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Access total in all routes (for development purposes)
DEV_EMAILS=email@example.com,email2@example.com