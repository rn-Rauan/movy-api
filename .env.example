# ========================================
# DATABASE CONFIGURATION
# ========================================

# Database URL for application
DATABASE_URL="postgres://docker:docker07@localhost:5705/movy?schema=public"

# Direct connection to the database (used for migrations)
# Note: use if you encounter migration issues
DIRECT_URL=""

# ========================================
# APPLICATION CONFIGURATION
# ========================================

# Server port
PORT=3001

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Enable Swagger UI at /api. Keep false in public production environments.
ENABLE_SWAGGER=false

# JWT secret key for signing tokens
JWT_SECRET=your_jwt_secret_key_here

# JWT expiration in seconds (1h = 3600, 7d = 604800)
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Access total in all routes (for development purposes)
DEV_EMAILS=email@example.com,email2@example.com

# ========================================
# SCHEDULED JOBS
# ========================================

# Set to "true" to skip ScheduleModule.forRoot() at boot — keeps the auto-cancel
# (and future recurring-generation) crons dormant during local dev.
# Read by AppModule synchronously, so dotenv must load before AppModule (see main.ts).
DISABLE_CRON=false
